# syntax=docker/dockerfile:1.6
#
# Standalone web container — builds the vite SPA bundle and serves it
# via nginx. Used in the prod docker-compose stack as the `web` service.
#
# Build:  docker build -f Dockerfile.web -t kobepay/kobe-web:latest .
# Serve:  port 80 with SPA fallback (every unknown path → /index.html).
#
# The reverse-proxy nginx in front of this container is what owns TLS
# and proxies /api/* + /socket.io/ to the api container. This container
# only knows about static files.

# ── Stage 1: Build the SPA bundle ────────────────────────────────────────────
FROM node:20-alpine AS build
WORKDIR /app

# Install deps first so the layer caches across source changes.
COPY package.json package-lock.json* ./
RUN npm install --legacy-peer-deps --no-audit --no-fund

# Bring in everything vite needs to build (src, index.html, configs).
COPY . .

# Override these at build time for white-label deploys:
#   --build-arg VITE_API_BASE=https://api.kobeapptz.com/api
#   --build-arg VITE_TENANT_BASE_DOMAIN=kobeapptz.com
ARG VITE_API_BASE=
ARG VITE_TENANT_BASE_DOMAIN=
ENV VITE_API_BASE=${VITE_API_BASE} \
    VITE_TENANT_BASE_DOMAIN=${VITE_TENANT_BASE_DOMAIN}

RUN npm run build

# ── Stage 2: Serve via nginx ─────────────────────────────────────────────────
FROM nginx:alpine AS runtime

# Drop the default site; copy our SPA-fallback config.
RUN rm -f /etc/nginx/conf.d/default.conf
COPY server/nginx/web-spa.conf /etc/nginx/conf.d/spa.conf

# Copy the built bundle. Vite outputs to /app/dist.
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
