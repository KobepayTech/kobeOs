# ═══════════════════════════════════════════════════════════════════════════════
# Cloudflare Pages Security Headers
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to dist/_headers after building.
# These security headers protect your app and enable PWA features.

/*
  # Prevent MIME-type sniffing
  X-Content-Type-Options: nosniff

  # Prevent clickjacking
  X-Frame-Options: DENY

  # Enable strict HTTPS (HSTS)
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

  # Content Security Policy — restrict what can load
  # Adjust 'connect-src' if your backend uses a different domain
  Content-Security-Policy: default-src 'self'; connect-src 'self' https://api.kobeapptz.com wss://*.kobeapptz.com https://*.cloudflareaccess.com; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; media-src 'self' blob:; worker-src 'self' blob:;

  # Referrer policy
  Referrer-Policy: strict-origin-when-cross-origin

  # Permissions policy (camera for QR scanning)
  Permissions-Policy: camera=(self), microphone=(), geolocation=(self), payment=(self)

  # Disable caching for HTML (service worker handles caching)
  Cache-Control: no-cache

/static/*
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable
