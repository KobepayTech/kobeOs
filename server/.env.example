NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=kobe
DB_PASSWORD=kobe
DB_DATABASE=kobeos
# Dev: leave true and rely on entity-driven schema sync.
# Prod: set to false and use migrations (DB_MIGRATIONS_RUN=true).
DB_SYNCHRONIZE=true
DB_MIGRATIONS_RUN=false

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
