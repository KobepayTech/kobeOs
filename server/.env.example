NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=kobe
DB_PASSWORD=kobe
DB_DATABASE=kobeos
# Dev: leave true and rely on entity-driven schema sync.
# Prod: set to false and use migrations (DB_MIGRATIONS_RUN=true).
DB_SYNCHRONIZE=true
DB_MIGRATIONS_RUN=false

JWT_SECRET=change-me-to-a-long-random-string
# Short-lived access token; refresh tokens cover sessions.
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_DAYS=30

# AI / LLM (Local inference via Ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:8b

# Live Football Data
# football-data.org — free tier, register at https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=
# api-football.com via RapidAPI — richer stats, xG, lineups (paid)
API_FOOTBALL_KEY=

# Kobe Model Distribution (runtime — served to clients)
# Leave unset to fall back to Ollama registry for model downloads.
# Set to your public CDN base URL once bundles are uploaded.
# Example: https://models.kobe  or  https://pub-xxx.r2.dev
KOBE_MODELS_CDN_URL=

# Kobe Model Distribution (build-time — used by scripts/upload-models.js)
# Cloudflare R2:  KOBE_CDN_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# MinIO:          KOBE_CDN_ENDPOINT=http://localhost:9000
KOBE_CDN_ENDPOINT=
KOBE_CDN_BUCKET=kobe-models
KOBE_CDN_ACCESS_KEY=
KOBE_CDN_SECRET_KEY=
KOBE_CDN_REGION=auto
# Public URL that maps to the bucket root (set after enabling R2 public access or custom domain)
KOBE_CDN_PUBLIC_URL=https://models.kobe

# ── Store Publishing (OPTIONAL — defaults are baked into the build) ──────────
#
# End users do NOT need to set any of these. KobeOS ships pre-configured
# for kobeapptz.com. Stores publish to {slug}.kobeapptz.com out of the box.
#
# Only uncomment and set these if you are running a white-label deployment
# on your own domain with your own Cloudflare account and registry server.
#
# Cloudflare Tunnel publishing (required for "Publish Store" to work)
# Token needs: Account:Cloudflare Tunnel:Edit  +  Zone:DNS:Edit
# CF_API_TOKEN=              # Cloudflare API token
# CF_ACCOUNT_ID=             # Cloudflare Account ID (from dashboard top-right)
# CF_ZONE_ID=                # Zone ID for kobeapptz.com (from domain overview sidebar)
# CF_DOMAIN=kobeapptz.com    # Base domain (default: kobeapptz.com)

# ── Creator marketplace ────────────────────────────────────────────────────────
# Required for creator platform sync (TikTok, Instagram, YouTube via ScrapeCreators)
# Get your key at https://scrapecreators.com — 100 free credits to start
SCRAPE_CREATORS_API_KEY=ilQndC78yWPEyO9oq3YCitj0TCC2

# ── PalmPesa payment gateway ───────────────────────────────────────────────────
# Used to collect creator subscription fees via USSD push
# Docs: https://documentation.palmpesa.co.tz
PALMPESA_API_TOKEN=0HNndAwG6NIXcksD1kRxHVHMgUtDi8GqgMfMQrymleH8HluAdA1ZRAl2jG3B
PALMPESA_USER_ID=531
# Public URL of this server — PalmPesa posts callbacks here
APP_PUBLIC_URL=https://api.kobeapptz.com
# (REGISTRY_HEARTBEAT_TOKEN and REGISTRY_API_URL are no longer used — removed in favour of Cloudflare Tunnels)

# ── OS License ─────────────────────────────────────────────────────────────────
# HMAC-SHA256 secret for signing offline license tokens.
# Must match VITE_LICENSE_HMAC_SECRET in the frontend build.
# Rotate this value to invalidate all existing tokens.
LICENSE_HMAC_SECRET=kobe-license-secret-change-in-prod

# ── Beem Africa (SMS / WhatsApp) ───────────────────────────────────────────────
# Docs: https://docs.beem.africa
# Both API key and Secret key are required to actually send. Leave blank to
# disable channel sends — the app keeps working, just without external pings.
BEEM_API_KEY=
BEEM_SECRET_KEY=
# Sender ID displayed on the recipient's phone (must be approved by Beem).
BEEM_SOURCE_ADDR=KOBE
# Override the SMS endpoint if you are using a non-default Beem environment.
# BEEM_SMS_URL=https://apisms.beem.africa/v1/send
