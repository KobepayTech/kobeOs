# ═══════════════════════════════════════════════════════════════════════════════
# KobeOS Production Environment
# ═══════════════════════════════════════════════════════════════════════════════
#
# This file is pre-configured for production. You ONLY need to fill in
# the 3 Cloudflare values below. Everything else is hardcoded.
#
# 1. Copy this file to .env:
#      cp .env.production .env
#
# 2. Fill in your Cloudflare credentials (from dash.cloudflare.com)
#
# 3. Start the server:
#      npm run start:prod

# ══ REQUIRED: Cloudflare (for store publishing) ══════════════════════════════
# Get these from https://dash.cloudflare.com:
#
# API Token:  My Profile → API Tokens → Create Token →
#             Template: "Cloudflare Tunnel:Edit" + "Zone:DNS:Edit"
CF_API_TOKEN=YOUR_CF_API_TOKEN_HERE
CF_ACCOUNT_ID=YOUR_CF_ACCOUNT_ID_HERE
CF_ZONE_ID=YOUR_CF_ZONE_ID_HERE

# ══ OPTIONAL: Override base domain (defaults to kobeapptz.com) ═══════════════
# CF_DOMAIN=kobeapptz.com

# ══ DATABASE (PostgreSQL) ════════════════════════════════════════════════════
NODE_ENV=production
PORT=3000
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=kobe
DB_PASSWORD=kobe
DB_DATABASE=kobeos
DB_SYNCHRONIZE=false
DB_MIGRATIONS_RUN=true

# ══ AUTH ═════════════════════════════════════════════════════════════════════
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_DAYS=30

# ══ AI / LLM (Ollama) ════════════════════════════════════════════════════════
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:8b
AI_VISION_MODEL=qwen2.5vl:7b

# ══ CORS ═════════════════════════════════════════════════════════════════════
# Allows the KobeOS desktop app to talk to the API
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# ══ PalmPesa (USSD payments) ═════════════════════════════════════════════════
PALMPESA_API_TOKEN=0HNndAwG6NIXcksD1kRxHVHMgUtDi8GqgMfMQrymleH8HluAdA1ZRAl2jG3B
PALMPESA_USER_ID=531
APP_PUBLIC_URL=https://api.kobeapptz.com

# ══ License ══════════════════════════════════════════════════════════════════
LICENSE_HMAC_SECRET=kobe-license-secret-change-in-prod
