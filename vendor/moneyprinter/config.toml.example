# MoneyPrinterTurbo config — KobeOS offline-first defaults.
#
# Copy this file to ./config/config.toml before the first compose up:
#   mkdir -p config && cp config.toml.example config/config.toml
#
# The defaults point at KobeOS's local Ollama process (set up via the
# `ai/llama-runtime/ollama-bridge.js` service) so the video pipeline
# runs FULLY OFFLINE with no OpenAI/Moonshot key. If you'd rather use a
# cloud provider, flip `llm_provider` and fill in the matching keys.

[app]

# ── LLM provider ────────────────────────────────────────────────────────
# Default: talk to the host's Ollama via OpenAI-compatible API.
# Requires the host to be running:   ollama serve
# And to have pulled one chat model:  ollama pull llama3.2:3b
llm_provider = "openai"
openai_api_key = "ollama"
openai_base_url = "http://host.docker.internal:11434/v1"
openai_model_name = "llama3.2:3b"

# If you'd rather use Mistral, Qwen with Swahili, or DeepSeek:
#   openai_model_name = "mistral:7b"          # general
#   openai_model_name = "qwen2.5:7b"          # strong Swahili / Arabic
#   openai_model_name = "deepseek-r1:8b"      # reasoning

# ── Stock footage ──────────────────────────────────────────────────────
# Pexels is free with an API key (https://www.pexels.com/api/).
# Pixabay is free too — either is fine.
pexels_api_keys = [""]
pixabay_api_keys = [""]

# ── Voiceover ──────────────────────────────────────────────────────────
# The upstream default is Microsoft Edge TTS, which DOES need the
# internet. Set use_piper = true to call KobeOS's local Piper service
# instead (ai/speech/piper-service.js, fully offline).
# NOTE: upstream MoneyPrinterTurbo doesn't yet read this flag; KobeOS's
# VideoGenerationService can swap the audio file post-render if needed.
use_piper = false
piper_voice = "en_US-amy-medium"

# ── Misc ───────────────────────────────────────────────────────────────
hide_config = false
endpoint = ""
material_directory = ""
max_concurrent_tasks = 5
